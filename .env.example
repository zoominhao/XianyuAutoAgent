# ===== AI 模型配置 =====
API_KEY=your_api_key_here
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen-vl-max

# ===== 闲鱼 Cookie =====
COOKIES_STR=your_cookies_here

# ===== 机器人行为 =====
TOGGLE_KEYWORDS=。
SIMULATE_HUMAN_TYPING=False

# ===== 通知方式 (email / wxpusher / 留空不通知) =====
NOTIFY_TYPE=email

# -- 邮件通知 --
EMAIL_NOTIFY_TO=your_email@qq.com
EMAIL_SMTP_SERVER=smtp.qq.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=your_email@qq.com
EMAIL_SMTP_PASSWORD=your_smtp_auth_code
EMAIL_USE_SSL=true

# -- WxPusher 微信通知 (可选) --
# WXPUSHER_APP_TOKEN=AT_xxx
# WXPUSHER_UID=UID_xxx
